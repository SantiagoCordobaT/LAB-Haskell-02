paresOrdenados = [(x, y) | x <- [1..5], y <- [1..5], x < y]

--2).
--a.
divisores :: Int -> [Int]
divisores n = [d | d <- [1..n], n `mod` d == 0]

--b.
divisoresPropios :: Int -> [Int]
divisoresPropios n = [d | d <- [1..n-1], n `mod` d == 0]

--c.
esPerfecto :: Int -> Bool
esPerfecto n = sum (divisoresPropios n) == n
